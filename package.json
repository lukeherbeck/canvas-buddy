{
  "name": "canvasbuddy",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:preview": "vite --port 5176 --open /preview/",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "convert": "xcrun safari-web-extension-converter dist --project-location xcode --app-name CanvasBuddy --bundle-identifier com.canvasbuddy.extension --no-open"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/firefox-webext-browser": "^120.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
